RewriteEngine On

# Redirect to HTTPS (uncomment on production if you have SSL)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Serve existing files and directories directly (CSS, JS, images, etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Serve uploaded logos from data/uploads/
RewriteRule ^uploads/([a-zA-Z0-9_\-]+\.(png|jpe?g|gif|webp|svg))$ data/uploads/$1 [L]

# Route everything else through index.php
RewriteRule ^ index.php [L,QSA]
