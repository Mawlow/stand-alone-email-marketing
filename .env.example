# Copy to .env and set your values
# App name (shown in UI)
APP_NAME="Standalone Email Marketing"

# Default admin account (created automatically if no admin exists). Only this account can access Admin, Senders, Design, API.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# MySQL (XAMPP)
DB_MYSQL_HOST=127.0.0.1
DB_MYSQL_PORT=3306
DB_MYSQL_DATABASE=email_marketing
DB_MYSQL_USERNAME=root
DB_MYSQL_PASSWORD=
DB_MYSQL_CHARSET=utf8mb4

# Public URL for images in emails and open tracking (e.g. https://yourdomain.com)
# Leave empty to use current host (images won't load for recipients on localhost)
TRACKING_BASE_URL=

# OpenAI API key (for AI Generate in Compose – professional email content)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Semaphore SMS API key (for SMS Notifications – send SMS to groups)
# Get your key at https://semaphore.co/
SEMAPHORE_API_KEY=

# Set to 0 if you get SSL certificate errors (e.g. on local Windows/XAMPP)
SEMAPHORE_SSL_VERIFY=1

# Set to 1 to use priority queue (sends immediately; 2 credits per 160 chars). Use if regular sends don't arrive.
SEMAPHORE_USE_PRIORITY=0

# Set to 1 to send params in URL query string (POST url?apikey=...&number=...). Try if SMS never arrive.
SEMAPHORE_QUERY_STRING=0

# Sender name shown to recipients. Leave empty to use Semaphore account default. Must be a name you registered at Semaphore.
# SEMAPHORE_SENDER_NAME=

# --- WhatsApp (Twilio) — default. https://console.twilio.com/ ---
# Sandbox: copy Account SID, Auth Token, sandbox "From" (e.g. whatsapp:+14155238886), join on your phone with Twilio’s code, then add that number as a recipient in the app.
# Production: after sender approval, set TWILIO_WHATSAPP_FROM to your live whatsapp:+ number.
# Optional: only if you need Facebook/Meta’s API: set WHATSAPP_PROVIDER=meta and fill the Meta variables below.
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=US5027a191b4704ca16b593c3764b701f5
TWILIO_AUTH_TOKEN=5c9262d15b4d593071320b40f4247e08
TWILIO_WHATSAPP_FROM=
# Optional — Twilio Content (approved templates). Filling "Template name" in the app enables this when set:
# TWILIO_WHATSAPP_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# JSON variables, e.g. {"1":"Alice"}
# TWILIO_WHATSAPP_CONTENT_VARIABLES=
# TWILIO_SSL_VERIFY=1

# --- Only if WHATSAPP_PROVIDER=meta (Meta Cloud API) — https://developers.facebook.com/docs/whatsapp/cloud-api ---
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_VERSION=v21.0
# WHATSAPP_SSL_VERIFY=1
